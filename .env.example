# ─── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=campusorbit

# ─── Auth ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ─── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://campusorbit-steel.vercel.app

# ─── Gmail SMTP (App Password) ─────────────────────────────────────────────────
#
# HOW TO GET YOUR APP PASSWORD (free, takes ~2 minutes):
#
#  1. Go to: https://myaccount.google.com/security
#  2. Under "How you sign in to Google", click 2-Step Verification → Turn it ON
#  3. Go back to Security page, scroll to "App Passwords" (search for it if hidden)
#  4. Click App Passwords
#     - Select app:    Mail
#     - Select device: Other → type  CampusOrbit
#     - Click Generate
#  5. Google shows a 16-character code like:  abcd efgh ijkl mnop
#  6. Copy it and paste into EMAIL_PASS  WITHOUT spaces and WITHOUT quotes
#     Correct:   EMAIL_PASS=abcdefghijklmnop
#     Wrong:     EMAIL_PASS="abcd efgh ijkl mnop"
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=campusorbit2026@gmail.com
EMAIL_PASS=aqdywtcckbbzvcll

# ─── Cloudinary (image uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
